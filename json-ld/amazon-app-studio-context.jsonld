{
  "@context": {
    "@version": 1.1,
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/",
    "appId": {
      "@id": "schema:identifier"
    },
    "name": {
      "@id": "schema:name"
    },
    "description": {
      "@id": "schema:description"
    },
    "status": {
      "@id": "schema:status",
      "@type": "xsd:string"
    },
    "createdAt": {
      "@id": "schema:dateCreated",
      "@type": "xsd:dateTime"
    },
    "updatedAt": {
      "@id": "schema:dateModified",
      "@type": "xsd:dateTime"
    }
  }
}